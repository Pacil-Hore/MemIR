# Salin file ini jadi `.env` lalu isi token bot dari Discord Developer Portal.
# Jangan commit `.env` (sudah di-gitignore).
DISCORD_TOKEN=your-bot-token-here

# --- Opsional (ada default di config.py / Dockerfile) ---
# Lokasi file DB. Di Docker sudah diset ke volume /data/memir.db.
# MEMIR_DB_PATH=memir.db
# Ganti tier model embedding (ingat: dimensi harus cocok).
# MEMIR_MODEL=intfloat/multilingual-e5-small
# Ambang similarity untuk kalibrasi.
# MEMIR_THRESHOLD=0.80
